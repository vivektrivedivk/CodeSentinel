<div class="nav-menu">
    <!-- Logo Section -->
    <div class="nav-header">
        <a href="/" class="logo-link">
            <div class="logo-icon">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 2L4 8V16C4 23.732 9.4 30.792 16 32C22.6 30.792 28 23.732 28 16V8L16 2Z" fill="url(#shield-gradient)" stroke="currentColor" stroke-width="1.5" />
                    <path d="M11 16L14.5 19.5L21 13" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                    <defs>
                        <linearGradient id="shield-gradient" x1="16" y1="2" x2="16" y2="32" gradientUnits="userSpaceOnUse">
                            <stop stop-color="currentColor" stop-opacity="0.2" />
                            <stop offset="1" stop-color="currentColor" stop-opacity="0.05" />
                        </linearGradient>
                    </defs>
                </svg>
            </div>
            @if (!Collapsed)
            {
                <span class="logo-text">CodeSentinel</span>
            }
        </a>
        @if (!Collapsed)
        {
            <button class="collapse-btn" @onclick="OnToggleSidebar" title="Collapse sidebar">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="11 17 6 12 11 7"></polyline>
                    <polyline points="18 17 13 12 18 7"></polyline>
                </svg>
            </button>
        }
    </div>

    <!-- Main Navigation -->
    <nav class="nav-section">
        @if (!Collapsed)
        {
            <div class="nav-label">Main</div>
        }
        <div class="nav-items">
            <NavLink href="/" class="nav-item" Match="NavLinkMatch.All">
                <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
                @if (!Collapsed)
                {
                    <span class="nav-text">Home</span>
                }
            </NavLink>

            <NavLink href="/chat" class="nav-item">
                <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                @if (!Collapsed)
                {
                    <span class="nav-text">Chat</span>
                    <span class="nav-badge">New</span>
                }
            </NavLink>

            <NavLink href="/repositories" class="nav-item">
                <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
                    <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
                    <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
                </svg>
                @if (!Collapsed)
                {
                    <span class="nav-text">Repositories</span>
                }
            </NavLink>

            <NavLink href="/history" class="nav-item">
                <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                @if (!Collapsed)
                {
                    <span class="nav-text">History</span>
                }
            </NavLink>
        </div>
    </nav>

    <!-- Tools Section -->
    <nav class="nav-section">
        @if (!Collapsed)
        {
            <div class="nav-label">Tools</div>
        }
        <div class="nav-items">
            <NavLink href="/settings" class="nav-item">
                <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
                @if (!Collapsed)
                {
                    <span class="nav-text">Settings</span>
                }
            </NavLink>
        </div>
    </nav>

    <!-- Footer Info -->
    @if (!Collapsed)
    {
        <div class="nav-footer">
            <div class="version-info">
                <span class="version-label">Version</span>
                <span class="version-number">1.0.0-beta</span>
            </div>
            <div class="shortcut-hint">
                <kbd>Ctrl</kbd> + <kbd>B</kbd> to toggle
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public bool Collapsed { get; set; }

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }
}