@page "/history"

<PageTitle>History - CodeSentinel</PageTitle>

<div class="history-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">Conversation History</h1>
            <p class="page-subtitle">View and manage your past conversations</p>
        </div>
        @if (_conversations.Count > 0)
        {
            <button class="btn btn-secondary" @onclick="ClearAllHistory">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
                Clear All
            </button>
        }
    </div>

    @if (_conversations.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <h3 class="empty-title">No conversations yet</h3>
            <p class="empty-text">Start chatting with CodeSentinel to see your conversation history here.</p>
            <a href="/chat" class="btn btn-primary">Start a Conversation</a>
        </div>
    }
    else
    {
        <div class="history-list">
            @foreach (var group in _groupedConversations)
            {
                <div class="history-group">
                    <h3 class="group-title">@group.Key</h3>
                    <div class="group-items">
                        @foreach (var conv in group.Value)
                        {
                            <div class="history-item">
                                <a href="/chat" class="item-link">
                                    <div class="item-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                                        </svg>
                                    </div>
                                    <div class="item-content">
                                        <h4 class="item-title">@conv.Title</h4>
                                        <p class="item-preview">@conv.Preview</p>
                                        <div class="item-meta">
                                            <span>@conv.MessageCount messages</span>
                                            <span>•</span>
                                            <span>@FormatTime(conv.LastActive)</span>
                                        </div>
                                    </div>
                                </a>
                                <div class="item-actions">
                                    <button class="action-btn" @onclick="() => DeleteConversation(conv)" title="Delete">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"></polyline>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Conversation> _conversations = new()
    {
        new Conversation { Title = "Authentication flow review", Preview = "Let's review the authentication middleware...", MessageCount = 12, LastActive = DateTime.Now.AddHours(-2) },
        new Conversation { Title = "Database query optimization", Preview = "Here are some suggestions to improve the query performance...", MessageCount = 8, LastActive = DateTime.Now.AddHours(-5) },
        new Conversation { Title = "API endpoint security", Preview = "I found a potential security issue in the user controller...", MessageCount = 15, LastActive = DateTime.Now.AddDays(-1) },
        new Conversation { Title = "React component refactoring", Preview = "The component can be simplified by extracting...", MessageCount = 6, LastActive = DateTime.Now.AddDays(-2) },
        new Conversation { Title = "Unit test coverage", Preview = "Here are the test cases for the service layer...", MessageCount = 20, LastActive = DateTime.Now.AddDays(-3) },
        new Conversation { Title = "Docker configuration", Preview = "The Dockerfile looks good, but consider adding...", MessageCount = 4, LastActive = DateTime.Now.AddDays(-5) },
    };

    private Dictionary<string, List<Conversation>> _groupedConversations => GroupConversations();

    private class Conversation
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = "";
        public string Preview { get; set; } = "";
        public int MessageCount { get; set; }
        public DateTime LastActive { get; set; }
    }

    private Dictionary<string, List<Conversation>> GroupConversations()
    {
        var groups = new Dictionary<string, List<Conversation>>();

        var today = _conversations.Where(c => c.LastActive.Date == DateTime.Today).ToList();
        if (today.Any()) groups["Today"] = today;

        var yesterday = _conversations.Where(c => c.LastActive.Date == DateTime.Today.AddDays(-1)).ToList();
        if (yesterday.Any()) groups["Yesterday"] = yesterday;

        var thisWeek = _conversations.Where(c =>
            c.LastActive.Date > DateTime.Today.AddDays(-7) &&
            c.LastActive.Date < DateTime.Today.AddDays(-1)).ToList();
        if (thisWeek.Any()) groups["This Week"] = thisWeek;

        var older = _conversations.Where(c => c.LastActive.Date <= DateTime.Today.AddDays(-7)).ToList();
        if (older.Any()) groups["Older"] = older;

        return groups;
    }

    private void DeleteConversation(Conversation conv)
    {
        _conversations.Remove(conv);
    }

    private void ClearAllHistory()
    {
        _conversations.Clear();
    }

    private string FormatTime(DateTime time)
    {
        var diff = DateTime.Now - time;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return time.ToString("MMM d, yyyy");
    }
}