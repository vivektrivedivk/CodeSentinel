@page "/settings"
@inject IJSRuntime JS

<PageTitle>Settings - CodeSentinel</PageTitle>

<div class="settings-page">
    <div class="settings-header">
        <h1 class="settings-title">Settings</h1>
        <p class="settings-subtitle">Configure your CodeSentinel experience</p>
    </div>

    <div class="settings-grid">
        <!-- API Configuration -->
        <section class="settings-section">
            <div class="section-header">
                <div class="section-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
                        <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
                        <line x1="6" y1="6" x2="6.01" y2="6"></line>
                        <line x1="6" y1="18" x2="6.01" y2="18"></line>
                    </svg>
                </div>
                <div>
                    <h2 class="section-title">API Configuration</h2>
                    <p class="section-description">Configure your Ollama connection settings</p>
                </div>
            </div>

            <div class="settings-form">
                <div class="form-group">
                    <label for="ollama-url">Ollama Base URL</label>
                    <div class="input-with-hint">
                        <input type="url" id="ollama-url" @bind="_settings.OllamaUrl" placeholder="http://localhost:11434" />
                        <span class="input-hint">The base URL where Ollama is running</span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="api-timeout">Request Timeout (seconds)</label>
                    <input type="number" id="api-timeout" @bind="_settings.RequestTimeout" min="10" max="300" />
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_settings.EnableStreaming" />
                        <span class="checkmark"></span>
                        <span class="label-text">Enable response streaming</span>
                    </label>
                    <span class="input-hint">Stream responses in real-time for a more interactive experience</span>
                </div>
            </div>
        </section>

        <!-- Model Settings -->
        <section class="settings-section">
            <div class="section-header">
                <div class="section-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                        <path d="M2 17l10 5 10-5"></path>
                        <path d="M2 12l10 5 10-5"></path>
                    </svg>
                </div>
                <div>
                    <h2 class="section-title">Model Settings</h2>
                    <p class="section-description">Choose and configure your AI model</p>
                </div>
            </div>

            <div class="settings-form">
                <div class="form-group">
                    <label for="default-model">Default Model</label>
                    <select id="default-model" @bind="_settings.DefaultModel">
                        <option value="deepseek-coder">DeepSeek Coder (Default)</option>
                        <option value="deepseek-coder:6.7b">DeepSeek Coder 6.7B</option>
                        <option value="codellama">CodeLlama</option>
                        <option value="codellama:7b">CodeLlama 7B</option>
                        <option value="llama2">Llama 2</option>
                        <option value="llama2:7b">Llama 2 7B</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="temperature">Temperature</label>
                    <div class="range-input">
                        <input type="range" id="temperature" @bind="_settings.Temperature" min="0" max="2" step="0.1" />
                        <span class="range-value">@_settings.Temperature</span>
                    </div>
                    <span class="input-hint">Higher values make output more random, lower values more deterministic</span>
                </div>

                <div class="form-group">
                    <label for="max-tokens">Max Tokens</label>
                    <input type="number" id="max-tokens" @bind="_settings.MaxTokens" min="100" max="8000" step="100" />
                    <span class="input-hint">Maximum number of tokens to generate in responses</span>
                </div>

                <div class="form-group">
                    <label for="context-length">Context Length</label>
                    <select id="context-length" @bind="_settings.ContextLength">
                        <option value="2048">2K tokens</option>
                        <option value="4096">4K tokens</option>
                        <option value="8192">8K tokens</option>
                        <option value="16384">16K tokens</option>
                    </select>
                </div>
            </div>
        </section>

        <!-- RAG Settings -->
        <section class="settings-section">
            <div class="section-header">
                <div class="section-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
                        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
                        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
                    </svg>
                </div>
                <div>
                    <h2 class="section-title">Repository Settings</h2>
                    <p class="section-description">Configure RAG and repository indexing</p>
                </div>
            </div>

            <div class="settings-form">
                <div class="form-group">
                    <label for="top-k">Top K Results</label>
                    <input type="number" id="top-k" @bind="_settings.TopK" min="1" max="20" />
                    <span class="input-hint">Number of relevant code snippets to include in context</span>
                </div>

                <div class="form-group">
                    <label for="chunk-size">Chunk Size</label>
                    <input type="number" id="chunk-size" @bind="_settings.ChunkSize" min="100" max="2000" step="100" />
                    <span class="input-hint">Size of code chunks for indexing (in characters)</span>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_settings.AutoIndex" />
                        <span class="checkmark"></span>
                        <span class="label-text">Auto-index repositories</span>
                    </label>
                    <span class="input-hint">Automatically index repositories when added</span>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_settings.ShowSources" />
                        <span class="checkmark"></span>
                        <span class="label-text">Show source references</span>
                    </label>
                    <span class="input-hint">Display referenced files in AI responses</span>
                </div>
            </div>
        </section>

        <!-- Appearance -->
        <section class="settings-section">
            <div class="section-header">
                <div class="section-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                </div>
                <div>
                    <h2 class="section-title">Appearance</h2>
                    <p class="section-description">Customize the look and feel</p>
                </div>
            </div>

            <div class="settings-form">
                <div class="form-group">
                    <label>Theme</label>
                    <div class="theme-options">
                        <button class="theme-option @(_settings.Theme == "dark" ? "active" : "")" @onclick='() => _settings.Theme = "dark"'>
                            <div class="theme-preview dark">
                                <div></div><div></div><div></div>
                            </div>
                            <span>Dark</span>
                        </button>
                        <button class="theme-option @(_settings.Theme == "light" ? "active" : "")" @onclick='() => _settings.Theme = "light"'>
                            <div class="theme-preview light">
                                <div></div><div></div><div></div>
                            </div>
                            <span>Light</span>
                        </button>
                        <button class="theme-option @(_settings.Theme == "system" ? "active" : "")" @onclick='() => _settings.Theme = "system"'>
                            <div class="theme-preview system">
                                <div></div><div></div><div></div>
                            </div>
                            <span>System</span>
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_settings.ShowLineNumbers" />
                        <span class="checkmark"></span>
                        <span class="label-text">Show line numbers in code blocks</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_settings.WordWrap" />
                        <span class="checkmark"></span>
                        <span class="label-text">Enable word wrap</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_settings.AnimationsEnabled" />
                        <span class="checkmark"></span>
                        <span class="label-text">Enable animations</span>
                    </label>
                </div>
            </div>
        </section>

        <!-- Keyboard Shortcuts -->
        <section class="settings-section">
            <div class="section-header">
                <div class="section-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="9" x2="15" y2="9"></line>
                        <line x1="9" y1="15" x2="15" y2="15"></line>
                    </svg>
                </div>
                <div>
                    <h2 class="section-title">Keyboard Shortcuts</h2>
                    <p class="section-description">Available shortcuts in the chat interface</p>
                </div>
            </div>

            <div class="shortcuts-list">
                <div class="shortcut-item">
                    <span class="shortcut-action">Send message</span>
                    <div class="shortcut-keys">
                        <kbd>Enter</kbd>
                    </div>
                </div>
                <div class="shortcut-item">
                    <span class="shortcut-action">New line</span>
                    <div class="shortcut-keys">
                        <kbd>Shift</kbd><span>+</span><kbd>Enter</kbd>
                    </div>
                </div>
                <div class="shortcut-item">
                    <span class="shortcut-action">Toggle sidebar</span>
                    <div class="shortcut-keys">
                        <kbd>Ctrl</kbd><span>+</span><kbd>B</kbd>
                    </div>
                </div>
                <div class="shortcut-item">
                    <span class="shortcut-action">Focus input</span>
                    <div class="shortcut-keys">
                        <kbd>/</kbd>
                    </div>
                </div>
                <div class="shortcut-item">
                    <span class="shortcut-action">Clear conversation</span>
                    <div class="shortcut-keys">
                        <kbd>Ctrl</kbd><span>+</span><kbd>Shift</kbd><span>+</span><kbd>X</kbd>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- Action Buttons -->
    <div class="settings-actions">
        <button class="btn btn-secondary" @onclick="ResetSettings">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 4 23 10 17 10"></polyline>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
            </svg>
            Reset to Defaults
        </button>
        <div class="actions-right">
            @if (_showSaved)
            {
                <span class="saved-indicator">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    Saved
                </span>
            }
            <button class="btn btn-primary" @onclick="SaveSettings">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                    <polyline points="17 21 17 13 7 13 7 21"></polyline>
                    <polyline points="7 3 7 8 15 8"></polyline>
                </svg>
                Save Changes
            </button>
        </div>
    </div>
</div>

@code {
    private SettingsModel _settings = new();
    private bool _showSaved = false;

    private class SettingsModel
    {
        // API
        public string OllamaUrl { get; set; } = "http://localhost:11434";
        public int RequestTimeout { get; set; } = 60;
        public bool EnableStreaming { get; set; } = true;

        // Model
        public string DefaultModel { get; set; } = "deepseek-coder";
        public double Temperature { get; set; } = 0.7;
        public int MaxTokens { get; set; } = 2048;
        public int ContextLength { get; set; } = 4096;

        // RAG
        public int TopK { get; set; } = 5;
        public int ChunkSize { get; set; } = 1000;
        public bool AutoIndex { get; set; } = true;
        public bool ShowSources { get; set; } = true;

        // Appearance
        public string Theme { get; set; } = "dark";
        public bool ShowLineNumbers { get; set; } = true;
        public bool WordWrap { get; set; } = true;
        public bool AnimationsEnabled { get; set; } = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        try
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "codesentinel-settings");
            if (!string.IsNullOrEmpty(saved))
            {
                _settings = System.Text.Json.JsonSerializer.Deserialize<SettingsModel>(saved) ?? new SettingsModel();
            }
        }
        catch
        {
            // Use defaults
        }
    }

    private async Task SaveSettings()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_settings);
            await JS.InvokeVoidAsync("localStorage.setItem", "codesentinel-settings", json);

            // Apply theme
            await JS.InvokeVoidAsync("document.documentElement.setAttribute", "data-theme",
                _settings.Theme == "system" ? "dark" : _settings.Theme);

            _showSaved = true;
            await Task.Delay(2000);
            _showSaved = false;
        }
        catch
        {
            // Handle error
        }
    }

    private void ResetSettings()
    {
        _settings = new SettingsModel();
    }
}