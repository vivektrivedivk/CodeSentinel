@page "/chat"
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@using System.Text.RegularExpressions
@inject HttpClient Http
@inject IJSRuntime JS
@implements IDisposable

<div class="chat-page">
    <!-- Chat Header -->
    <div class="chat-header">
        <div class="header-left">
            <h1 class="chat-title">AI Assistant</h1>
            <span class="chat-subtitle">Powered by DeepSeek Coder</span>
        </div>
        <div class="header-right">
            <!-- Model Selector -->
            <div class="model-selector">
                <select @bind="_selectedModel" class="model-select">
                    <option value="deepseek-coder">DeepSeek Coder</option>
                    <option value="deepseek-coder:6.7b">DeepSeek Coder 6.7B</option>
                    <option value="codellama">CodeLlama</option>
                    <option value="llama2">Llama 2</option>
                </select>
            </div>
            
            <!-- Clear Chat Button -->
            <button class="btn btn-ghost btn-sm" @onclick="ClearConversation" title="Clear conversation" disabled="@(_messages.Count == 0)">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
                @if (_showLabels)
                {
                    <span>Clear</span>
                }
            </button>
            
            <!-- Token Count -->
            @if (_messages.Count > 0)
            {
                <div class="token-count" title="Estimated tokens">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <span>@_estimatedTokens tokens</span>
                </div>
            }
        </div>
    </div>

    <!-- Messages Container -->
    <div class="messages-container" @ref="_messageListRef">
        @if (_messages.Count == 0 && !_streaming)
        {
            <!-- Welcome State -->
            <div class="welcome-state">
                <div class="welcome-icon">
                    <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M16 2L4 8V16C4 23.732 9.4 30.792 16 32C22.6 30.792 28 23.732 28 16V8L16 2Z" fill="url(#welcome-gradient)" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M11 16L14.5 19.5L21 13" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <defs>
                            <linearGradient id="welcome-gradient" x1="16" y1="2" x2="16" y2="32" gradientUnits="userSpaceOnUse">
                                <stop stop-color="currentColor" stop-opacity="0.2"/>
                                <stop offset="1" stop-color="currentColor" stop-opacity="0.05"/>
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
                <h2 class="welcome-title">Welcome to CodeSentinel</h2>
                <p class="welcome-text">Ask me anything about your codebase. I can help with:</p>
                <div class="welcome-suggestions">
                    <button class="suggestion-chip" @onclick='() => SetQuery("Explain this code")'>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                        Explain code
                    </button>
                    <button class="suggestion-chip" @onclick='() => SetQuery("Find bugs in this function")'>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        Find bugs
                    </button>
                    <button class="suggestion-chip" @onclick='() => SetQuery("Refactor this code")'>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="16 3 21 8 8 21 3 21 3 16 16 3"></polygon></svg>
                        Refactor
                    </button>
                    <button class="suggestion-chip" @onclick='() => SetQuery("Write tests for this")'>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 12 15 16 10"></polyline></svg>
                        Write tests
                    </button>
                </div>
            </div>
        }
        else
        {
            @foreach (var msg in _messages)
            {
                <div class="message @(msg.IsUser ? "user" : "assistant") @(msg.IsEditing ? "editing" : "")" id="msg-@msg.Id">
                    <!-- Message Header -->
                    <div class="message-header">
                        <div class="message-avatar">
                            @if (msg.IsUser)
                            {
                                <span class="avatar-text">You</span>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="9" y1="9" x2="15" y2="9"></line>
                                    <line x1="9" y1="15" x2="15" y2="15"></line>
                                </svg>
                            }
                        </div>
                        <div class="message-meta">
                            <span class="message-author">@(msg.IsUser ? "You" : "CodeSentinel")</span>
                            <span class="message-time" title="@msg.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")">@FormatTimestamp(msg.Timestamp)</span>
                        </div>
                        @if (!msg.IsUser && msg.Id == _messages.LastOrDefault(m => !m.IsUser)?.Id)
                        {
                            <div class="message-actions">
                                <button class="action-btn" @onclick="() => RegenerateResponse(msg)" title="Regenerate response">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="23 4 23 10 17 10"></polyline>
                                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>

                    <!-- Message Content -->
                    <div class="message-content">
                        @if (msg.IsEditing)
                        {
                            <textarea @bind="_editText" @bind:event="oninput" class="edit-textarea" rows="3" @onkeydown="(e) => HandleEditKeyDown(e, msg)" @onkeydown:preventDefault></textarea>
                            <div class="edit-actions">
                                <button class="btn btn-primary btn-sm" @onclick="() => SaveEdit(msg)">Save</button>
                                <button class="btn btn-secondary btn-sm" @onclick="() => CancelEdit(msg)">Cancel</button>
                            </div>
                        }
                        else
                        {
                            @if (msg.IsUser)
                            {
                                <div class="message-text">@msg.Text</div>
                            }
                            else
                            {
                                <div class="message-markdown">
                                    @((MarkupString)RenderMarkdown(msg.Text))
                                </div>
                            }
                        }
                    </div>

                    <!-- Sources (for assistant messages) -->
                    @if (!msg.IsUser && msg.Sources?.Count > 0)
                    {
                        <div class="message-sources">
                            <div class="sources-header" @onclick="() => ToggleSources(msg.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="@(_expandedSources.Contains(msg.Id) ? "expanded" : "")">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                                <span>Sources (@msg.Sources.Count)</span>
                            </div>
                            @if (_expandedSources.Contains(msg.Id))
                            {
                                <ul class="sources-list">
                                    @foreach (var source in msg.Sources)
                                    {
                                        <li class="source-item">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                                <polyline points="14 2 14 8 20 8"></polyline>
                                            </svg>
                                            <span class="source-path">@source</span>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    }

                    <!-- Message Footer (for user messages) -->
                    @if (msg.IsUser && !msg.IsEditing)
                    {
                        <div class="message-footer">
                            <button class="action-btn" @onclick="() => StartEdit(msg)" title="Edit message">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            }

            <!-- Streaming Message -->
            @if (_streaming)
            {
                <div class="message assistant streaming">
                    <div class="message-header">
                        <div class="message-avatar">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="9" y1="9" x2="15" y2="9"></line>
                                <line x1="9" y1="15" x2="15" y2="15"></line>
                            </svg>
                        </div>
                        <div class="message-meta">
                            <span class="message-author">CodeSentinel</span>
                            <span class="typing-indicator">
                                <span class="dot"></span>
                                <span class="dot"></span>
                                <span class="dot"></span>
                            </span>
                        </div>
                    </div>
                    <div class="message-content">
                        <div class="message-markdown">
                            @((MarkupString)RenderMarkdown(_streamBuffer.ToString()))
                        </div>
                        <span class="cursor">▋</span>
                    </div>
                </div>
            }
        }

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="error-banner">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <span>@_errorMessage</span>
                <button class="btn btn-primary btn-sm" @onclick="RetryLastMessage">Retry</button>
                <button class="btn btn-ghost btn-sm" @onclick="() => _errorMessage = null">Dismiss</button>
            </div>
        }
    </div>

    <!-- Input Area -->
    <div class="input-area">
        <div class="input-container">
            <!-- File Attachment (Future Feature) -->
            <button class="attach-btn" title="Attach file (coming soon)" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                </svg>
            </button>

            <!-- Text Input -->
            <div class="textarea-wrapper">
                <textarea 
                    @bind="_query" 
                    @bind:event="oninput"
                    @onkeydown="HandleKeyDown"
                    @onkeydown:preventDefault
                    placeholder="Ask about your codebase…"
                    rows="1"
                    class="chat-input"
                    disabled="@_streaming"
                    @ref="_inputRef"
                ></textarea>
                <div class="input-hints">
                    <span class="hint">
                        <kbd>Enter</kbd> to send
                    </span>
                    <span class="hint">
                        <kbd>Shift</kbd> + <kbd>Enter</kbd> for new line
                    </span>
                </div>
            </div>

            <!-- Send Button -->
            <button 
                class="send-btn @(!string.IsNullOrWhiteSpace(_query) ? "active" : "")" 
                @onclick="SendAsync"
                disabled="@(_streaming || string.IsNullOrWhiteSpace(_query))"
                title="Send message"
            >
                @if (_streaming)
                {
                    <svg class="spinner" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="2" x2="12" y2="6"></line>
                        <line x1="12" y1="18" x2="12" y2="22"></line>
                        <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line>
                        <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line>
                        <line x1="2" y1="12" x2="6" y2="12"></line>
                        <line x1="18" y1="12" x2="22" y2="12"></line>
                        <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line>
                        <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line>
                    </svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                }
            </button>
        </div>
    </div>
</div>

@code {
   
}