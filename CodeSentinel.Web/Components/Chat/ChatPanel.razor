@page "/chat"
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS

<div class="chat-container">
    <div class="message-list" @ref="_messageListRef">
        @foreach (var msg in _messages)
        {
            <div class="message @(msg.IsUser ? "user" : "assistant")">
                <pre>@msg.Text</pre>
                @if (msg.Sources?.Count > 0)
                {
                    <ul class="sources">
                        @foreach (var s in msg.Sources)
                        {
                            <li>@s</li>
                        }
                    </ul>
                }
            </div>
        }
        @if (_streaming)
        {
            <div class="message assistant streaming">
                <pre>@_streamBuffer</pre>
                <span class="cursor">▋</span>
            </div>
        }
    </div>

    <div class="input-bar">
        <textarea @bind="_query"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  placeholder="Ask about your codebase…"
                  rows="3"
                  disabled="@_streaming" />
        <button @onclick="() => Console.WriteLine('C')">
            @(_streaming ? "Thinking…" : "Send")
        </button>
    </div>
</div>

<style>
    .chat-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .message-list {
        flex: 1;
        overflow-y: auto;
        padding: 20px 0;
    }

    .message {
        margin-bottom: 20px;
        padding: 15px;
        border-radius: 8px;
    }

    .message.user {
        background-color: #007bff;
        color: white;
        margin-left: 20%;
    }

    .message.assistant {
        background-color: #f0f0f0;
        color: #333;
        margin-right: 20%;
    }

    .message pre {
        margin: 0;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .message.streaming {
        border: 2px dashed #007bff;
    }

    .cursor {
        display: inline-block;
        animation: blink 1s infinite;
        color: #007bff;
    }

    @@keyframes blink {
        0%, 50% { opacity: 1; }
        51%, 100% { opacity: 0; }
    }

    .sources {
        margin-top: 10px;
        padding-left: 20px;
        font-size: 0.9em;
        color: #666;
    }

    .input-bar {
        display: flex;
        gap: 10px;
        padding: 20px 0;
        border-top: 1px solid #ddd;
    }

    .input-bar textarea {
        flex: 1;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-family: inherit;
        resize: vertical;
    }

    .input-bar button {
        padding: 10px 20px;
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }

    .input-bar button:disabled {
        background-color: #ccc;
        cursor: not-allowed;
    }
</style>
